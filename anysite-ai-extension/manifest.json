{
  "manifest_version": 3,
  "name": "Bricks AI",
  "version": "1.0",
  "permissions": [
    "sidePanel", 
    "activeTab", 
    "scripting", 
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": { "service_worker": "bg.js" },
  "side_panel": { "default_path": "ui.html" },
  "action": {}
}